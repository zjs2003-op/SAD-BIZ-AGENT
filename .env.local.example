# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# OrbisX — get from OrbisX Admin → Integrations / API
ORBISX_API_KEY=your-orbisx-key
ORBISX_API_BASE=https://orbisx.ca
ORBISX_EVENTS_PATH=/api/v1/events
ORBISX_AUTH_STYLE=bearer
